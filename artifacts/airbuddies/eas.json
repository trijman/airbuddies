{
  "cli": {
    "version": ">= 16.0.0",
    "appVersionSource": "local"
  },
  "build": {
    "development": {
      "developmentClient": true,
      "distribution": "internal",
      "pnpm": "10.26.1",
      "ios": {
        "simulator": false
      }
    },
    "preview": {
      "distribution": "internal",
      "credentialsSource": "remote",
      "config": "ios-preview.yml",
      "ios": {
        "buildConfiguration": "Release",
        "artifactPath": "ios/Airbuddies.ipa"
      }
    },
    "production": {
      "autoIncrement": true,
      "pnpm": "10.26.1",
      "ios": {}
    }
  },
  "submit": {
    "production": {}
  }
}
